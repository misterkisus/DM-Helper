generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id             String      @id @default(cuid())
  name           String
  isPlayer       Boolean     @default(true)
  defaultInitMod Int         @default(0)
  notes          String?
  createdAt      DateTime    @default(now())
  combatants     Combatant[]
}

model Encounter {
  id            String      @id @default(cuid())
  name          String      @default("Бой")
  round         Int         @default(1)
  activeId      String?
  status        String      @default("idle") // idle | running | finished
  isCurrent     Boolean     @default(false)
  displayMode   String      @default("scene") // scene | exploration
  activeImageId String?
  publishedAt   DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  combatants    Combatant[]
}

model SceneImage {
  id        String   @id @default(cuid())
  name      String
  path      String
  mimeType  String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

model Combatant {
  id          String      @id @default(cuid())
  encounterId String
  characterId String?
  displayName String
  isPlayer    Boolean     @default(false)
  initiative  Int         @default(0)
  tiebreaker  Int         @default(0)
  currentHp   Int?
  maxHp       Int?
  hasActed    Boolean     @default(false)
  order       Int         @default(0)
  conditions  Condition[]

  encounter Encounter  @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([encounterId])
}

model Condition {
  id          String  @id @default(cuid())
  combatantId String
  slug        String
  value       Int?

  combatant Combatant @relation(fields: [combatantId], references: [id], onDelete: Cascade)

  @@index([combatantId])
}
